# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# Backups & scratch
*.bak
*.tmp
_nco_loose_backup_*/

# Large prebuilt bundle (rebuild from source; keep repo lean)
neuro-commerce-os.mcpb

# TOKEN SHIELD (v2.0) — raw client docs & generated output stay local.
# The repo is PUBLIC: raw_docs may contain proprietary client material
# and must never be committed. output/ is regenerable.
output/
knowledge/raw_docs/
*.docx
*.pdf
*.pptx

# RAG / memory databases (rebuilt by ingest.js / runtime)
*.db
*.sqlite

# Personal (machine-local) Claude Code settings — never commit
.claude/settings.local.json

# Logs
*.log

# NOTE: mcp-server/node_modules IS committed on purpose so the plugin runs
# out-of-the-box when installed from this marketplace (Claude Code does not
# run `npm install` on plugin install). Do not add it here.
