  "server": {
    "type": "node",
    "entry_point": "mcp-server/src/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/mcp-server/src/index.js"],
      "env": {
        "SERPAPI_API_KEY": "",
        "TAVILY_API_KEY": "",
        "RECRAFT_API_KEY": "",
        "LEONARDO_API_KEY": "",
        "SD_API_URL": "",
        "META_ACCESS_TOKEN": "",
        "META_AD_ACCOUNT_ID": ""
      }
    }
  },
  "tools": [
    {"name": "execute_phase1_diagnostic"}, {"name": "execute_phase2_brand_architecture"},
    {"name": "execute_phase3_content_production"}, {"name": "execute_phase4_ads_campaign"},
    {"name": "execute_phase5_growth_intelligence"}, {"name": "generate_persona_architecture"},
    {"name": "analyze_market_intelligence"}, {"name": "create_content_strategy"},
    {"name": "deploy_ads_campaign"}, {"name": "generate_learning_loop"},
    {"name": "calculate_unit_economics"}, {"name": "run_iron_dome_qa"},
    {"name": "generate_image_asset"}, {"name": "generate_voiceover"},
    {"name": "calculate_virality_score"}, {"name": "detect_creative_fatigue"},
    {"name": "score_churn_risk"}, {"name": "diagnose_video_content"},
    {"name": "score_social_content"}
