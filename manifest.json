{
  "dxt_version": "0.1",
  "name": "neuro-commerce-os",
  "display_name": "Neuro-Commerce OS",
  "version": "1.3.0",
  "description": "Complete Neuro-Commerce OS engine — 19 MCP tools driving the NextLuma 5-phase framework (Diagnostic → Brand → Content → Ads → Growth) plus video/social reel diagnostics. Free-tool fallbacks built in.",
  "author": {
    "name": "NextLuma Agency"
  },
  "license": "UNLICENSED",
